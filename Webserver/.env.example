# Environment variables for Smart Bookshelf Web Application
# Copy this file to .env.local and fill in the values

# --- Database ---
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:Salkin263@192.168.1.154:5432/Smart-Bookshelf"

# --- Authentication (NextAuth / Auth.js) ---
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# Application base URL (used by NextAuth for callbacks)
AUTH_URL="http://localhost:3000"

# --- Email (Nodemailer) ---
# SMTP configuration for transactional email
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your@email.com"
SMTP_PASS="your-email-password"
EMAIL_FROM="Smart Bookshelf <noreply@example.com>"

# --- Book Metadata (optional, for future integration) ---
# GOOGLE_BOOKS_API_KEY=""
# OPEN_LIBRARY_API_URL="https://openlibrary.org"
